# ── Required ──────────────────────────────────────────────────
# Your Signal phone number (E.164 format)
SIGNAL_NUMBER=+1234567890

# ── Signal API ────────────────────────────────────────────────
# URL of the signal-cli-rest-api container
SIGNAL_API_URL=http://signal-api:8080

# ── Transcription Backend ────────────────────────────────────
# "local" = faster-whisper (free, private, default)
# "openai" = OpenAI Whisper API (requires OPENAI_API_KEY)
TRANSCRIPTION_BACKEND=local

# ── OpenAI (required for "openai" backend or GPT formatting) ─
# OPENAI_API_KEY=sk-...

# Set to "true" to enable GPT formatting (requires OPENAI_API_KEY)
# ENABLE_GPT_FORMATTING=false

# ── Privacy / Consent ─────────────────────────────────────────
# Who can have their voice messages transcribed:
#   "own_only"  — only your own voice messages (default, most private)
#   "allowlist" — only numbers listed in ALLOWED_NUMBERS
#   "all"       — every voice message (use only if all contacts consent)
TRANSCRIBE_MODE=own_only

# Comma-separated phone numbers (only used when TRANSCRIBE_MODE=allowlist)
# ALLOWED_NUMBERS=+14155551234,+14155555678

# ── Logging ───────────────────────────────────────────────────
# Python log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
