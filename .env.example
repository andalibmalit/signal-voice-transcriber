# ── Required ──────────────────────────────────────────────────
# Your Signal phone number (E.164 format)
SIGNAL_NUMBER=+1234567890

# ── Signal API ────────────────────────────────────────────────
# URL of the signal-cli-rest-api container
SIGNAL_API_URL=http://signal-api:8080

# ── Transcription Backend ────────────────────────────────────
# "local" = faster-whisper (free, private, default)
# "openai" = OpenAI Whisper API (requires OPENAI_API_KEY)
TRANSCRIPTION_BACKEND=local

# ── Local Whisper Settings ───────────────────────────────────
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=small

# Quantization: int8, float16, float32
WHISPER_COMPUTE_TYPE=int8

# Device: cpu or auto (auto uses GPU if available)
WHISPER_DEVICE=cpu

# Number of CPU threads for inference
WHISPER_CPU_THREADS=4

# Language code (en, de, etc.) or "auto" for auto-detection
WHISPER_LANGUAGE=auto

# Directory for cached model files (Docker volume mount point)
WHISPER_MODEL_DIR=/models

# ── Optional: OpenAI Cloud Features ─────────────────────────
# Uncomment to enable OpenAI Whisper API and/or GPT formatting
# OPENAI_API_KEY=sk-...

# GPT model for optional transcript formatting (requires OPENAI_API_KEY)
# GPT_MODEL=gpt-4o-mini

# Set to "true" to enable GPT formatting (requires OPENAI_API_KEY)
# ENABLE_GPT_FORMATTING=false

# Timeout for OpenAI API calls (seconds)
# OPENAI_TIMEOUT_SECONDS=120

# ── Privacy / Consent ─────────────────────────────────────────
# Who can have their voice messages transcribed:
#   "own_only"  — only your own voice messages (default, most private)
#   "allowlist" — only numbers listed in ALLOWED_NUMBERS
#   "all"       — every voice message (use only if all contacts consent)
TRANSCRIBE_MODE=own_only

# Comma-separated phone numbers (only used when TRANSCRIBE_MODE=allowlist)
# ALLOWED_NUMBERS=+14155551234,+14155555678

# ── Limits ────────────────────────────────────────────────────
# Skip voice messages larger than this (MB). OpenAI Whisper API limit is 25 MB.
MAX_AUDIO_SIZE_MB=25

# ── Logging ───────────────────────────────────────────────────
# Python log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
